# Copy to .env and fill in: cp .env.example .env

# Phase 2: Embeddings (ChromaDB or Pinecone)
OPENAI_API_KEY=your_openai_api_key_here

# Phase 3: Generation
GROQ_API_KEY=your_groq_api_key_here

# Optional: vector store (default: chroma). Use "pinecone" for Vercel.
# VECTOR_STORE_TYPE=chroma
# VECTOR_STORE_TYPE=pinecone

# Optional: Pinecone (when VECTOR_STORE_TYPE=pinecone)
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=mutual-fund-faq
# PINECONE_ENV=us-east-1-aws

# Optional: override models
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# GROQ_MODEL=llama-3.1-8b-instant
